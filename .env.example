# Copy to .env and fill in. Never commit .env.

# Azure Blob Storage (for raw PDFs + parsed artifacts)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER_RAW=raw-pdfs
AZURE_STORAGE_CONTAINER_PARSED=parsed
# Prefer Entra ID (DefaultAzureCredential). Connection string is a fallback.
AZURE_STORAGE_CONNECTION_STRING=

# Azure AI Document Intelligence
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_CHUNKS=tax-chunks
AZURE_SEARCH_INDEX_SENTENCES=tax-sentences

# Azure AI Foundry (AIServices account) + Azure OpenAI deployments for the
# RAG generator role. Same endpoint serves both the OpenAI SDK and the
# Foundry project.
#
# Auth: Entra ID via DefaultAzureCredential (az login locally, workload
# identity in CI). The caller needs "Cognitive Services User" on the
# Foundry account (covers the AOAI gpt-4o deployment) AND "Azure AI User"
# on the Foundry project (covers the MaaS serverless deployments). Grant
# with:
#   az role assignment create --assignee <upn-or-objectId> \
#     --role "Cognitive Services User" \
#     --scope /subscriptions/<sub>/resourceGroups/rg-phrase-citation-testing/providers/Microsoft.CognitiveServices/accounts/<foundry-name>
# API keys below are retained only as a break-glass fallback and are NOT
# required by the current code path.
AZURE_FOUNDRY_NAME=
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_PROJECT_NAME=sentcite
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Synth-GT author role (non-OpenAI family; e.g. Llama-3.3-70B-Instruct).
# Populate after click-deploying the model from the Foundry Model Catalog.
FOUNDRY_SYNTH_GT_ENDPOINT=
FOUNDRY_SYNTH_GT_API_KEY=
FOUNDRY_SYNTH_GT_DEPLOYMENT=
FOUNDRY_SYNTH_GT_MODEL=

# Judge role (third distinct model family; e.g. DeepSeek-V3 or Phi-4).
FOUNDRY_JUDGE_ENDPOINT=
FOUNDRY_JUDGE_API_KEY=
FOUNDRY_JUDGE_DEPLOYMENT=
FOUNDRY_JUDGE_MODEL=
